# Forrest RSOS — environment template. Copy to .env.local and fill in.
# NEVER commit real secrets. Feature-flag defaults below encode the team's
# governance votes (CLAUDE.md rule #4) — keep these defaults.

# ---------- Supabase (Work4Vince Org) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=

# ---------- FMCSA / MOTUS ----------
FMCSA_QCMOBILE_WEBKEY=
FMCSA_DATAHUB_BASE_URL=
LOGIN_GOV_CLIENT_ID=
LOGIN_GOV_CLIENT_SECRET=

# ---------- M365 connectors (org is M365-standardized) ----------
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
TEAMS_WEBHOOK_URL=
SHAREPOINT_SITE_URL=
TABLEAU_EXPORT_URL=

# ---------- Samsara (own-fleet, separate view) ----------
SAMSARA_API_TOKEN=

# ---------- TMS connector (interface-first; Q5 pending) ----------
TMS_API_BASE_URL=
TMS_API_KEY=

# ---------- Governance feature flags (defaults = team votes; do not flip casually) ----------
# Dispatch blocking ships DORMANT/advisory until the team ratifies enforcing mode (Q15).
FEATURE_DISPATCH_BLOCK_ENFORCING=false
# No always-on AI assistant (team: Discuss).
FEATURE_AI_ASSISTANT=false
# COI OCR is parse-and-prefill only — NEVER auto-approves.
FEATURE_COI_OCR=true
